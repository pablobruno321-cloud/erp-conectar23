# Copia este archivo a .env y llena los valores
# NO commits .env a GitHub (ya está en .gitignore)

# Clave secreta de Flask (genera con: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=tu-clave-secreta-super-larga-aqui

# Entorno: development o production
FLASK_ENV=development

# Base de datos (local: sqlite, producción: postgresql)
DATABASE_URL=sqlite:///erp.db

# Configuración de email (opcional, para notificaciones)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-email@gmail.com
# MAIL_PASSWORD=tu-app-password
